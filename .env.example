# Copy to `.env` locally if you need a fixed canonical origin (optional in dev).
#
# Production / preview: Vercel injects `VERCEL_URL`; production also has
# `VERCEL_PROJECT_PRODUCTION_URL`. This repo still recommends setting the
# public origin explicitly so sitemap, robots, and Open Graph match the URL
# you show in the browser — especially for custom domains and subdomains.
#
# Examples:
#   NEXT_PUBLIC_BASE_URL=https://www.ptoq.io
#   NEXT_PUBLIC_BASE_URL=https://labs.ptoq.io
#   NEXT_PUBLIC_BASE_URL=https://machinedie.life
#   NEXT_PUBLIC_BASE_URL=https://liferestart.ptoq.io
NEXT_PUBLIC_BASE_URL=

# Full resolution order and subdomains: docs/base-url.md
